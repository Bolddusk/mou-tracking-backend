PORT=5000
DATABASE_URL=mysql://root:yourpassword@localhost:3306/pk_china_portal
JWT_SECRET=change-me-jwt-secret-min-32-chars-long!!
JWT_EXPIRES_IN=7d
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_INPUT_CHARS=18000
AI_PARSE_LOCAL_FALLBACK=false

# Party A/B invite email (nodemailer)
# Bypass until SMTP works on server: EMAIL_ENABLED=false + RETURN_PARTY_*_CREDENTIALS_IN_RESPONSE=true
EMAIL_ENABLED=false
EMAIL_HOST=s9623.fra1.stableserver.net
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_ENCRYPTION=ssl
EMAIL_USER=no-reply@yourdomain.com
EMAIL_PASS="your_password_with_special_chars"
EMAIL_FROM_NAME=AVRIO
EMAIL_FROM=AVRIO <no-reply@yourdomain.com>
CLIENT_LOGIN_URL=http://localhost:5173/auth/login
PORTAL_NAME=Pakistan-China Investment Portal

# Return Party A/B temp password in approve API when email disabled or send fails
RETURN_PARTY_B_CREDENTIALS_IN_RESPONSE=true

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# PDF export (SIFC reports) — Puppeteer needs Chrome/Chromium
# Docker image sets these automatically:
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# Bare metal / PM2: leave unset — postinstall downloads Chrome, or run:
# npm run puppeteer:install-chrome
